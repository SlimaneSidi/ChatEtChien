<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.CaptchaController"
           fx:id="rootContainer"
           styleClass="captcha-overlay">

    <StackPane styleClass="captcha-backdrop"
               onMouseClicked="#handleBackdropClick"/>

    <VBox fx:id="mainContainer"
          styleClass="captcha-root"
          spacing="14"
          alignment="CENTER"
          maxWidth="460"
          maxHeight="700">

        <padding>
            <Insets top="22" right="26" bottom="18" left="26"/>
        </padding>

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🔒" style="-fx-font-size: 20px;"/>
            <VBox spacing="2">
                <Label text="Vérification de sécurité" styleClass="captcha-title"/>
                <Label text="reCAPTCHA™ — ISEN" styleClass="captcha-version"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="✕" styleClass="captcha-close-btn" onMouseClicked="#handleClose"/>
        </HBox>

        <Separator/>

        <!-- INSTRUCTION -->
        <VBox spacing="4" alignment="CENTER">
            <Label fx:id="titleLabel"
                   text="Prouvez que vous n'êtes pas un robot"
                   styleClass="captcha-main-title"
                   wrapText="true" textAlignment="CENTER"/>
            <Label fx:id="instructionLabel"
                   text="Cliquez sur toutes les images de 🐱 CHATS"
                   styleClass="captcha-instruction"
                   wrapText="true" textAlignment="CENTER"/>
        </VBox>

        <!-- GRILLE 3x3 -->
        <GridPane fx:id="imageGrid" hgap="8" vgap="8" alignment="CENTER">
            <padding><Insets top="4" bottom="4"/></padding>
        </GridPane>

        <!-- STATUS -->
        <Label fx:id="statusLabel" text=""
               styleClass="captcha-status"
               wrapText="true" textAlignment="CENTER"
               minHeight="22" maxWidth="400"/>

        <Separator/>

        <!-- BARRE ROBOT -->
        <VBox spacing="5">
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="robotLabel"
                       text="Probabilité d'être un robot : 0%"
                       styleClass="robot-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="attemptsLabel"
                       text="0 / 3 tentatives"
                       styleClass="attempts-label"/>
            </HBox>
            <ProgressBar fx:id="robotBar" progress="0"
                         maxWidth="Infinity" prefHeight="12"
                         styleClass="robot-bar"/>
        </VBox>

        <Separator/>

        <!-- BOUTONS -->
        <HBox spacing="12" alignment="CENTER">
            <Button text="🔄  Nouvelle grille"
                    onAction="#handleRefresh"
                    styleClass="captcha-refresh-btn"
                    prefWidth="155" prefHeight="40"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="verifyBtn"
                    text="✓  Valider"
                    onAction="#handleVerify"
                    styleClass="captcha-verify-btn"
                    prefWidth="210" prefHeight="40"/>
        </HBox>

    </VBox>

</StackPane>