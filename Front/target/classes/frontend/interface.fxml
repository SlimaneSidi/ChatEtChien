<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.Controller"
            styleClass="analyse-root">

    <!-- ========== HEADER ========== -->
    <top>
        <VBox styleClass="header">

            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="nav-bar">
                <Label text="← Accueil" styleClass="back-button"
                       onMouseClicked="#handleBack"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="🐱 Cat vs Dog AI 🐶" styleClass="nav-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🎮 Mini‑Jeu"
                        onAction="#handleMiniGame"
                        styleClass="mini-game-button"/>
                <Button text="🔒 CAPTCHA"
                        onAction="#handleOpenCaptcha"
                        styleClass="captcha-button"/>
            </HBox>

            <Separator styleClass="header-separator"/>

            <VBox alignment="CENTER" spacing="4" styleClass="header-content">
                <Label text="Classification d'Images" styleClass="main-title"/>
                <Label text="Glissez une image ou cliquez pour analyser"
                       styleClass="main-subtitle"/>
            </VBox>

        </VBox>
    </top>

    <!-- ========== CONTENT ========== -->
    <center>
        <HBox spacing="0" styleClass="analyse-root">

            <!-- ===== PANNEAU GAUCHE ===== -->
            <VBox spacing="20" styleClass="left-panel" HBox.hgrow="ALWAYS">

                <!-- Zone de drop -->
                <VBox styleClass="drop-section" VBox.vgrow="NEVER">
                    <Label text="📂  Zone d'analyse" styleClass="panel-title"/>

                    <StackPane fx:id="dropZone" styleClass="drop-zone"
                               prefHeight="360" minHeight="360" maxHeight="360">

                        <!-- Icône -->
                        <VBox fx:id="dropHint" alignment="CENTER" spacing="12">
                            <Label text="📁" styleClass="drop-icon"/>
                            <Label text="Glissez votre image ici"
                                   styleClass="drop-main-text"/>
                            <Label text="ou cliquez pour parcourir"
                                   styleClass="drop-sub-text"/>
                            <HBox alignment="CENTER" spacing="8">
                                <Label text="JPG" styleClass="format-tag"/>
                                <Label text="PNG" styleClass="format-tag"/>
                                <Label text="BMP" styleClass="format-tag"/>
                            </HBox>
                        </VBox>

                        <ImageView fx:id="previewImage"
                                   fitWidth="400" fitHeight="340"
                                   preserveRatio="true"
                                   visible="false"
                                   styleClass="preview-image"/>

                    </StackPane>
                </VBox>

                <!-- Boutons d'action -->
                <HBox spacing="15" alignment="CENTER">
                    <Button fx:id="analyzeBtn" text="🔍  Analyser"
                            onAction="#handleAnalyze"
                            styleClass="btn-analyze"
                            prefWidth="180" prefHeight="50"/>
                    <Button fx:id="clearBtn" text="🗑  Effacer"
                            onAction="#handleClear"
                            styleClass="btn-clear"
                            prefWidth="180" prefHeight="50"/>
                </HBox>

                <!-- Infos image -->
                <HBox fx:id="imageInfoBox" spacing="20" alignment="CENTER"
                      styleClass="image-info-bar" visible="false">
                    <Label fx:id="imageNameLabel" text="nom.jpg" styleClass="info-chip"/>
                    <Label fx:id="imageSizeLabel" text="800x600" styleClass="info-chip"/>
                    <Label fx:id="imageWeightLabel" text="120 Ko" styleClass="info-chip"/>
                </HBox>

            </VBox>

            <Separator orientation="VERTICAL" styleClass="vertical-separator"/>

            <!-- ===== PANNEAU DROIT ===== -->
            <ScrollPane fitToWidth="true"
                        hbarPolicy="NEVER"
                        vbarPolicy="AS_NEEDED"
                        styleClass="right-scroll"
                        prefWidth="380" minWidth="380" maxWidth="380"
                        HBox.hgrow="NEVER">

                <VBox spacing="20" styleClass="right-panel"
                      prefWidth="360" minWidth="360">

                    <!-- Résultat principal -->
                    <VBox styleClass="result-section" spacing="15">
                        <Label text="🎯  Résultat" styleClass="panel-title"/>

                        <!-- Carte résultat -->
                        <VBox fx:id="resultPanel" styleClass="result-card"
                              alignment="CENTER" spacing="12" visible="false">

                            <Label fx:id="resultEmoji" text="🐱" styleClass="result-emoji"/>
                            <Label fx:id="resultLabel" text="CHAT" styleClass="result-label"/>

                            <!-- Badge confiance faible -->
                            <Label fx:id="lowConfidenceLabel"
                                   text="⚠️ Confiance insuffisante"
                                   styleClass="low-confidence-badge"
                                   visible="false"/>

                            <!-- Barre confiance globale -->
                            <VBox spacing="6" alignment="CENTER">
                                <HBox alignment="CENTER_LEFT" spacing="5">
                                    <Label text="Confiance" styleClass="confidence-text"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="confidencePercent" text="0%"
                                           styleClass="confidence-percent"/>
                                </HBox>
                                <ProgressBar fx:id="confidenceBar" progress="0"
                                             prefWidth="280" prefHeight="14"
                                             styleClass="confidence-bar"/>
                            </VBox>

                            <!-- Barres chat / chien / wild -->
                            <GridPane hgap="10" vgap="10" styleClass="stats-grid">

                                <!-- CHAT -->
                                <HBox alignment="CENTER_LEFT" spacing="5"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="🐱" style="-fx-font-size: 13px;"/>
                                    <Label text="Chat" styleClass="stat-label"/>
                                </HBox>
                                <ProgressBar fx:id="catBar" progress="0" prefWidth="140"
                                             prefHeight="9" styleClass="cat-bar"
                                             GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                <Label fx:id="catPercent" text="0%"
                                       styleClass="stat-percent"
                                       GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                                <!-- CHIEN -->
                                <HBox alignment="CENTER_LEFT" spacing="5"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1">
                                    <Label text="🐶" style="-fx-font-size: 13px;"/>
                                    <Label text="Chien" styleClass="stat-label"/>
                                </HBox>
                                <ProgressBar fx:id="dogBar" progress="0" prefWidth="140"
                                             prefHeight="9" styleClass="dog-bar"
                                             GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label fx:id="dogPercent" text="0%"
                                       styleClass="stat-percent"
                                       GridPane.columnIndex="2" GridPane.rowIndex="1"/>

                                <!-- WILD -->
                                <HBox alignment="CENTER_LEFT" spacing="5"
                                      GridPane.columnIndex="0" GridPane.rowIndex="2">
                                    <Label text="🦁" style="-fx-font-size: 13px;"/>
                                    <Label text="Wild" styleClass="stat-label"/>
                                </HBox>
                                <ProgressBar fx:id="wildBar" progress="0" prefWidth="140"
                                             prefHeight="9" styleClass="wild-bar"
                                             GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                                <Label fx:id="wildPercent" text="0%"
                                       styleClass="stat-percent"
                                       GridPane.columnIndex="2" GridPane.rowIndex="2"/>

                            </GridPane>

                        </VBox>

                        <!-- Placeholder -->
                        <VBox fx:id="resultPlaceholder" styleClass="result-placeholder"
                              alignment="CENTER" spacing="10">
                            <Label text="🔮" styleClass="placeholder-icon"/>
                            <Label text="En attente d'une image..."
                                   styleClass="placeholder-text"/>
                        </VBox>

                    </VBox>

                    <!-- Stats session -->
                    <VBox styleClass="stats-section" spacing="12">
                        <Label text="📊  Session" styleClass="panel-title"/>

                        <GridPane hgap="10" vgap="10">

                            <VBox styleClass="stat-card" alignment="CENTER" spacing="4"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label fx:id="totalAnalyses" text="0" styleClass="stat-number"/>
                                <Label text="Analyses" styleClass="stat-name"/>
                            </VBox>

                            <VBox styleClass="stat-card" alignment="CENTER" spacing="4"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label fx:id="totalChats" text="0" styleClass="stat-number"/>
                                <Label text="🐱 Chats" styleClass="stat-name"/>
                            </VBox>

                            <VBox styleClass="stat-card" alignment="CENTER" spacing="4"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label fx:id="totalChiens" text="0" styleClass="stat-number"/>
                                <Label text="🐶 Chiens" styleClass="stat-name"/>
                            </VBox>

                            <VBox styleClass="stat-card" alignment="CENTER" spacing="4"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label fx:id="totalWild" text="0" styleClass="stat-number"/>
                                <Label text="🦁 Wild" styleClass="stat-name"/>
                            </VBox>

                            <VBox styleClass="stat-card stat-card-avg" alignment="CENTER" spacing="4"
                                  GridPane.columnIndex="0" GridPane.rowIndex="2"
                                  GridPane.columnSpan="2">
                                <Label fx:id="avgConfidence" text="0%" styleClass="stat-number"/>
                                <Label text="Confiance moyenne" styleClass="stat-name"/>
                            </VBox>

                        </GridPane>
                    </VBox>

                    <!-- Logs -->
                    <VBox styleClass="log-section" spacing="8" VBox.vgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="📋  Logs" styleClass="panel-title-dark"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="Effacer" onAction="#handleClearLog"
                                    styleClass="btn-log-clear"/>
                        </HBox>
                        <TextArea fx:id="logArea" editable="false"
                                  VBox.vgrow="ALWAYS" prefHeight="150"
                                  styleClass="log-area"/>
                    </VBox>

                </VBox>
            </ScrollPane>

        </HBox>
    </center>

</BorderPane>
